            </entry>
            <entry key="default">
              <object type="KCCS.GSmartClient.Core.Web.GFileDownloadResponseParser, KCCS.GSmartClient.Core" singleton="true"/>
            </entry>
          </dictionary>
        </constructor-arg>
      </object>
    </constructor-arg>
  </object>

