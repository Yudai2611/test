		<Column name="StepEndDate" phyName="End_Time" type="Date" />
		<Column name="StepStatus" phyName="Status" type="Varchar" size="10" />
		<Column name="CommitCount" phyName="Commit_Count" type="Long" size="19" />
		<Column name="ReadCount" phyName="Read_Count" type="Long" size="19" />
		<Column name="FilterCount" phyName="Filter_Count" type="Long" size="19" />
		<Column name="StepUpdateCount" phyName="Write_Count" type="Long" size="19" />
		<Column name="ReadSkipCount" phyName="Read_Skip_Count" type="Long" size="19" />
		<Column name="WriteSkipCount" phyName="Write_Skip_Count" type="Long" size="19" />
