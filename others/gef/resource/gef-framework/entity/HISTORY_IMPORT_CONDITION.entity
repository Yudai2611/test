            <JoinColumn srcName="HistoryId" refName="HistoryId" />
        </ForeignKey>
        <ForeignKey name="FkSortFields" refEntity="HISTORY_IMPORT_CONDITION_SORT_FIELD">
            <JoinColumn srcName="ApplicationId" refName="ApplicationId" />
