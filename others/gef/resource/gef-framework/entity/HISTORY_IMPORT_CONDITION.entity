	<ForeignKeys>
		<ForeignKey name="FkImportFields" refEntity="HISTORY_IMPORT_CONDITION_IMPORT_FIELD">
			<JoinColumn srcName="ApplicationId" refName="ApplicationId" />
			<JoinColumn srcName="HistoryId" refName="HistoryId" />
		</ForeignKey>
		<ForeignKey name="FkFilterFields" refEntity="HISTORY_IMPORT_CONDITION_FILTER_FIELD">
