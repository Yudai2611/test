<!-- Define application events listeners -->
	<!-- フレームワークの初期化 -->
	<listener>
		<listener-class>jp.co.kccs.greenearth.framework.GMVCFrameworkInitializer</listener-class>
	</listener>
	<!--
	<listener>
		<listener-class>jp.co.kccs.greenearth.framework.session.GSessionManagerImpl</listener-class>
	</listener>
	-->

<!-- Define servlets  -->
	<!-- Smart Client -->
	<servlet>
		<servlet-name>ActionServlet</servlet-name>
		<servlet-class>jp.co.kccs.greenearth.framework.GActionServlet</servlet-class>
		<load-on-startup>8</load-on-startup>
	</servlet>

	<!-- RIA Client -->
	<servlet>
		<servlet-name>ViewActionServlet</servlet-name>
		<servlet-class>jp.co.kccs.greenearth.framework.view.GViewActionServlet</servlet-class>
		<init-param>
			<param-name>ui-tld/ria-rich</param-name>
			<param-value>/WEB-INF/ge-ria-rich.tld</param-value>
		</init-param>
		<init-param>
			<param-name>ui-tld/ria-plain</param-name>
			<param-value>/WEB-INF/ge-ria-plain.tld</param-value>
		</init-param>
		<init-param>
			<param-name>ui-tld/ria-function</param-name>
			<param-value>/WEB-INF/ge-ria-function.tld</param-value>
		</init-param>
		<init-param>
			<param-name>ui-tld/fqe-ria</param-name>
			<param-value>/WEB-INF/ge-fqe-ria.tld</param-value>
		</init-param>
		<load-on-startup>30</load-on-startup>
	</servlet>

<!-- Define servlet mapping -->
	<!-- RIA Client -->
	<servlet-mapping>
		<servlet-name>ViewActionServlet</servlet-name>
		<url-pattern>*.view-action</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>ViewActionServlet</servlet-name>
		<url-pattern>*.ajax-action</url-pattern>
	</servlet-mapping>

	<!-- Smart Client -->
	<servlet-mapping>
		<servlet-name>ActionServlet</servlet-name>
		<url-pattern>*.xrmi-action</url-pattern>
	</servlet-mapping>

<!-- Define session -->
	<session-config>
		<session-timeout>30</session-timeout>
	</session-config>

<!-- Define JSPs  -->
	<jsp-config>
		<!-- RIA -->
 		<taglib>
			<taglib-uri>http://www.kccs.co.jp/geframe/ria/plain/taglib</taglib-uri>
			<taglib-location>/WEB-INF/ge-ria-plain.tld</taglib-location>
		</taglib>
 		<taglib>
			<taglib-uri>http://www.kccs.co.jp/geframe/ria/rich/taglib</taglib-uri>
			<taglib-location>/WEB-INF/ge-ria-rich.tld</taglib-location>
		</taglib>
 		<taglib>
			<taglib-uri>http://www.kccs.co.jp/geframe/ria/function/taglib</taglib-uri>
			<taglib-location>/WEB-INF/ge-ria-function.tld</taglib-location>
		</taglib>
		<taglib>
			<taglib-uri>http://www.kccs.co.jp/geframe/fqe/ria/taglib</taglib-uri>
			<taglib-location>/WEB-INF/ge-fqe-ria.tld</taglib-location>
		</taglib>
		<jsp-property-group>
 			<url-pattern>*.jsp</url-pattern>
			<!-- true is non use el tag. -->
   			<el-ignored>false</el-ignored>
 			<page-encoding>UTF-8</page-encoding>
			<!-- true is non use Scriptlet. -->
			<scripting-invalid>false</scripting-invalid>
		</jsp-property-group>
	</jsp-config>

<!-- Defin welcome page -->
	<welcome-file-list>
		<welcome-file>login.jsp</welcome-file>
	</welcome-file-list>

<!-- Define error page -->
	<error-page>
		<exception-type>java.lang.Throwable</exception-type>
		<location>/public/jsp/common/system-error.jsp</location>
	</error-page>

<!-- Define Resource ref -->
	<resource-ref>
		<res-ref-name>jdbc/JavaKitDataSource</res-ref-name>
		<res-type>javax.sql.DataSource</res-type>
		<res-auth>Container</res-auth>
	</resource-ref>

</web-app>