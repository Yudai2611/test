<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">

<!-- Define filters -->
	<!-- リクエストエンコーディング  -->
	<filter>
		<filter-name>CharacterEncodingFilter</filter-name>
		<filter-class>jp.co.kccs.greenearth.framework.GSetCharacterEncodingFilter</filter-class>
		<init-param>
			<param-name>encoding</param-name>
			<param-value>UTF-8</param-value>
		</init-param>
	</filter>
	<filter>
		<filter-name>CharacterEncodingFilter4Xrmi</filter-name>
		<filter-class>jp.co.kccs.greenearth.framework.GSetCharacterEncodingFilter</filter-class>
		<init-param>
			<param-name>encoding</param-name>
			<param-value>Windows-31J</param-value>
		</init-param>
	</filter>
	

	<!-- DIコンテナ Webスコープ設定 -->
	<filter>
		<filter-name>DIContainerFilter</filter-name>
		<filter-class>org.springframework.web.filter.RequestContextFilter</filter-class>
	</filter>

	<!-- セッション同期 -->
	<!--
	<filter>
		<filter-name>SyncronizedSessionFilter</filter-name>
		<filter-class>jp.co.kccs.greenearth.framework.session.GSynchronizedSessionFilter</filter-class>
	</filter>
	-->

	<!-- FacadeFilter -->
	<filter>
		<filter-name>FacadeFilter</filter-name>
		<filter-class>jp.co.kccs.greenearth.framework.GFacadeFilter</filter-class>
	</filter>
	<!-- ResponseWriter -->
	<filter>
		<filter-name>ViewResponseFilter</filter-name>
		<filter-class>jp.co.kccs.greenearth.framework.view.GViewResponseFilter</filter-class>
		<init-param>
			<param-name>error-page</param-name>
			<param-value>
					[{exception:"jp.co.kccs.greenearth.framework.auth.GAuthenticationException", path:"/public/jsp/common/auth-error.jsp"},
					 {exception:"java.lang.Throwable", path:"/public/jsp/common/system-error.jsp"}]
			</param-value>
		</init-param>
		<init-param>
			<param-name>exclude-url/system-error.jsp</param-name>
			<param-value>/public/jsp/common/system-error.jsp</param-value>
		</init-param>
	</filter>

	<filter>
		<filter-name>AjaxResponseFilter</filter-name>
		<filter-class>jp.co.kccs.greenearth.framework.richview.GAjaxResponseFilter</filter-class>
		<init-param>
			<param-name>error-page</param-name>
			<param-value>
					[{exception:"jp.co.kccs.greenearth.framework.auth.GAuthenticationException", path:"/WEB-INF/jsp/sample/ria/common/auth-error-dialog.jsp"},
					 {exception:"java.lang.Throwable", path:"/WEB-INF/jsp/sample/ria/common/system-error-dialog.jsp"}]
			</param-value>
		</init-param>
		<init-param>
			<param-name>exclude-url/system-error-dialog.jsp</param-name>
			<param-value>/WEB-INF/jsp/sample/ria/common/system-error-dialog.jsp</param-value>
		</init-param>
	</filter>

	<filter>
		<filter-name>XrmiResponseFilter</filter-name>
		<filter-class>jp.co.kccs.greenearth.framework.xrmi.GXrmiResponseFilter</filter-class>
	</filter>
	
	<!-- 認証チェック -->
	<filter>
		<filter-name>AuthVerifyFilter</filter-name>
		<filter-class>jp.co.kccs.greenearth.framework.auth.GAuthVerifyFilter</filter-class>
		<!-- RIA Client -->
		<init-param>
			<param-name>exclude-url/login.view-action</param-name>
			<param-value>/login.view-action</param-value>
		</init-param>
		<init-param>
			<param-name>exclude-url/login.jsp</param-name>
			<param-value>/login.jsp</param-value>
		</init-param>
		<init-param>
			<param-name>exclude-url/system-error.jsp</param-name>
			<param-value>/public/jsp/common/system-error.jsp</param-value>
		</init-param>
		<init-param>
			<param-name>exclude-url/auth-error.jsp</param-name>
			<param-value>/public/jsp/common/auth-error.jsp</param-value>
		</init-param>
		<!-- Smart Client -->
		<init-param>
			<param-name>exclude-url/login.xrmi-action</param-name>
			<param-value>/Login.xrmi-action</param-value>
		</init-param>
	</filter>
	
	<!-- ワンタイムトークン -->
	<filter>
		<filter-name>VerifyOneTimeTokenFilter</filter-name>
		<filter-class>jp.co.kccs.greenearth.framework.GVerifyOneTimeTokenFilter</filter-class>
		<init-param>
			<param-name>suffix</param-name>
			<param-value>WidthVerifyToken</param-value>
		</init-param>
	</filter>
	
	<!-- FQEContextの初期化 -->
	<filter>
		<filter-name>FqeContextFilter</filter-name>
		<filter-class>jp.co.kccs.greenearth.framework.fqecore.context.GFqeContextFilter</filter-class>
	</filter>

