<!-- Define Filter Mapping -->
	<!-- リクエストエンコーディング  -->
	<filter-mapping>
		<filter-name>CharacterEncodingFilter</filter-name>
		<url-pattern>/*</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>CharacterEncodingFilter4Xrmi</filter-name>
		<url-pattern>*.xrmi-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>

	<!-- DIコンテナ Webスコープ設定 -->
    <filter-mapping>
		<filter-name>DIContainerFilter</filter-name>
		<url-pattern>/*</url-pattern>
		<dispatcher>REQUEST</dispatcher>
		<dispatcher>ERROR</dispatcher>
	</filter-mapping>

	<!-- FacadeFilter -->
	<filter-mapping>
		<filter-name>FacadeFilter</filter-name>
		<url-pattern>*.view-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>FacadeFilter</filter-name>
		<url-pattern>*.jsp</url-pattern>
		<dispatcher>REQUEST</dispatcher>
		<dispatcher>ERROR</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>FacadeFilter</filter-name>
		<url-pattern>*.xrmi-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>FacadeFilter</filter-name>
		<url-pattern>*.ajax-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>

	<!-- ResponseWriter -->
	<filter-mapping>
		<filter-name>ViewResponseFilter</filter-name>
		<url-pattern>*.view-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>ViewResponseFilter</filter-name>
		<url-pattern>*.jsp</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>XrmiResponseFilter</filter-name>
		<url-pattern>*.xrmi-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>AjaxResponseFilter</filter-name>
		<url-pattern>*.ajax-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>

	<!-- 認証チェック -->
	<filter-mapping>
		<filter-name>AuthVerifyFilter</filter-name>
		<url-pattern>*.view-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>AuthVerifyFilter</filter-name>
		<url-pattern>*.jsp</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>AuthVerifyFilter</filter-name>
		<url-pattern>*.xrmi-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>AuthVerifyFilter</filter-name>
		<url-pattern>*.ajax-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	
	<!-- ワンタイムトークン -->
	<filter-mapping>
		<filter-name>VerifyOneTimeTokenFilter</filter-name>
		<url-pattern>*.view-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>VerifyOneTimeTokenFilter</filter-name>
		<url-pattern>*.jsp</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>VerifyOneTimeTokenFilter</filter-name>
		<url-pattern>*.ajax-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	
	<!-- FQEContextの初期化 -->
	<filter-mapping>
		<filter-name>FqeContextFilter</filter-name>
		<url-pattern>*.view-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>FqeContextFilter</filter-name>
		<url-pattern>*.jsp</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter-mapping>
		<filter-name>FqeContextFilter</filter-name>
		<url-pattern>*.ajax-action</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>

