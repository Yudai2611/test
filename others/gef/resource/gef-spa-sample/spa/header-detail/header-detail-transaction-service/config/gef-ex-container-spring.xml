<?xml version="1.0" encoding="UTF-8"?>
 <beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:util="http://www.springframework.org/schema/util"
	xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
           http://www.springframework.org/schema/util
           http://www.springframework.org/schema/util/spring-util-3.0.xsd
          ">

<!-- ###########################
           gef-ex
     ########################### -->

	<bean name="jp.co.kccs.greenearth.framework.ex.action.GActionParameterHandlerFactory" class="jp.co.kccs.greenearth.framework.ex.action.GActionParameterHandlerFactoryImpl" scope="singleton">
		<constructor-arg>
			<map>
				<entry key="gef-ria-client">
					<bean class="jp.co.kccs.greenearth.framework.ex.action.GRIAActionParameterHandler" />
				</entry>
				<entry key="gef-smart-client">
					<bean class="jp.co.kccs.greenearth.framework.ex.action.GXRMIActionParameterHandler" />
				</entry>
			</map>
		</constructor-arg>
	</bean>
	<bean name="jp.co.kccs.greenearth.framework.log.log4j.GLogCompanyCodePatternFormatter" class="jp.co.kccs.greenearth.framework.log.log4j.GLogCompanyCodePatternFormatter" scope="singleton">
		<constructor-arg value="companycd" />
	</bean>
	<bean name="jp.co.kccs.greenearth.framework.log.log4j.GLogUserIdPatternFormatter" class="jp.co.kccs.greenearth.framework.log.log4j.GLogUserIdPatternFormatter" scope="singleton">
		<constructor-arg value="userid" />
	</bean>
	<bean name="jp.co.kccs.greenearth.framework.log.log4j.GLogMenuIdPatternFormatter" class="jp.co.kccs.greenearth.framework.log.log4j.GLogMenuIdPatternFormatter" scope="singleton">
		<constructor-arg value="menuid" />
	</bean>
</beans>