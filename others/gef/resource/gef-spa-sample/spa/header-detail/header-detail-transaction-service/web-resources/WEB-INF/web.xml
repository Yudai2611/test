<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee"
		 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		 xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">

	<!-- DIコンテナ Webスコープ設定 -->
	<filter>
		<filter-name>DIContainerFilter</filter-name>
		<filter-class>org.springframework.web.filter.RequestContextFilter</filter-class>
	</filter>
	<!-- DIコンテナ Webスコープ設定 -->
	<filter-mapping>
		<filter-name>DIContainerFilter</filter-name>
		<url-pattern>/*</url-pattern>
		<dispatcher>REQUEST</dispatcher>
		<dispatcher>ERROR</dispatcher>
	</filter-mapping>
	<listener>
		<listener-class>jp.co.kccs.greenearth.framework.GMVCFrameworkInitializer</listener-class>
	</listener>


	<!-- Actionエンドポイント　-->
	<servlet>
		<servlet-name>SPAServlet</servlet-name>
		<servlet-class>jp.co.kccs.greenearth.framework.web.server.GServletContainer</servlet-class>
		<init-param>
			<param-name>filters</param-name>
			<param-value>
				jp.co.kccs.greenearth.framework.web.filter.GGenericFilterChainProxy
			</param-value>
		</init-param>
	</servlet>
	<servlet-mapping>
		<servlet-name>SPAServlet</servlet-name>
		<url-pattern>*.spa-action</url-pattern>
	</servlet-mapping>

	<welcome-file-list>
		<welcome-file>welcome.html</welcome-file>
	</welcome-file-list>

</web-app>